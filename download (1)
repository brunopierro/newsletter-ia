name: Radar de IA

on:
  schedule:
    # 11:00 UTC = 08:00 no horário de Brasília. "*/2" = dias ímpares do mês (a cada ~2 dias).
    - cron: "0 11 */2 * *"
  workflow_dispatch: {}   # permite disparar manualmente para testar

permissions:
  contents: write          # necessário para comitar state/ e archive/

jobs:
  gerar:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Instalar dependências
        run: pip install -r requirements.txt

      - name: Gerar e enviar newsletter
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
          SMTP_HOST: ${{ secrets.SMTP_HOST }}
          SMTP_PORT: ${{ secrets.SMTP_PORT }}
          SMTP_USER: ${{ secrets.SMTP_USER }}
          SMTP_PASS: ${{ secrets.SMTP_PASS }}
          EMAIL_FROM: ${{ secrets.EMAIL_FROM }}
          EMAIL_TO: ${{ secrets.EMAIL_TO }}
        run: python newsletter.py

      - name: Comitar estado e arquivo da edição
        run: |
          git config user.name "radar-ia-bot"
          git config user.email "actions@users.noreply.github.com"
          git add state archive
          git commit -m "edição ${{ github.run_id }}" || echo "sem mudanças para comitar"
          git push
